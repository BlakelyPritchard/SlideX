# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/slidex

# AI Configuration (choose one)

# Option 1: Ollama (FREE, Local, Open-Source) - RECOMMENDED
# See OLLAMA_SETUP.md for installation instructions
USE_OLLAMA=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llava
USE_OCR=true

# Option 2: IBM WatsonX.ai (Enterprise, Cloud)
WATSONX_IAM_API_KEY=your_watsonx_iam_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Option 3: OpenAI (Cloud, Paid)
OPENAI_API_KEY=your_openai_api_key_here

# Option 4: Anthropic Claude (Cloud, Paid)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Option 5: Roo (Bob) API (Alternative)
ROO_API_KEY=your_roo_api_key_here
ROO_API_URL=https://api.roo.ai/v1

# Application Settings
APP_ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production

# File Upload Settings
MAX_UPLOAD_SIZE=50000000  # 50MB in bytes
UPLOAD_DIR=./uploads
SLIDES_DIR=./slides
THUMBNAILS_DIR=./thumbnails

# CORS Settings
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Server Settings
HOST=0.0.0.0
PORT=8000